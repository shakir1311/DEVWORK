  <diagram name="Security Architecture v3 - Portrait" id="sec-portrait">
    <mxGraphModel dx="1000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        
        <!-- Header -->
        <mxCell id="header" value="" style="rounded=0;fillColor=#1e293b;strokeColor=none" vertex="1" parent="1"><mxGeometry width="850" height="70" as="geometry"/></mxCell>
        <mxCell id="title" value="BIEIF-RPM: Security Architecture v3" style="text;fontSize=20;fontStyle=1;fontColor=#fff" vertex="1" parent="1"><mxGeometry x="30" y="12" width="400" height="26" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="Zero Trust Framework • PKI • mTLS • Hardware Security • Defense-in-Depth" style="text;fontSize=10;fontColor=#94a3b8" vertex="1" parent="1"><mxGeometry x="30" y="40" width="450" height="16" as="geometry"/></mxCell>
        <mxCell id="zt" value="ZERO TRUST" style="rounded=1;fillColor=#7c3aed;strokeColor=none;fontSize=9;fontStyle=1;fontColor=#fff" vertex="1" parent="1"><mxGeometry x="720" y="22" width="85" height="22" as="geometry"/></mxCell>
        
        <!-- ZONE 0: PKI -->
        <mxCell id="z0" value="" style="rounded=1;fillColor=#faf5ff;strokeColor=#c4b5fd;strokeWidth=2;dashed=1" vertex="1" parent="1"><mxGeometry x="30" y="90" width="790" height="130" as="geometry"/></mxCell>
        <mxCell id="z0t" value="🔐 ZONE 0: PKI TRUST INFRASTRUCTURE" style="text;fontSize=11;fontStyle=1;fontColor=#5b21b6" vertex="1" parent="1"><mxGeometry x="45" y="98" width="280" height="16" as="geometry"/></mxCell>
        <mxCell id="rootca" value="🔒 Root CA&#xa;(Air-Gapped Offline)&#xa;━━━━━━━━━━&#xa;• Self-signed root&#xa;• Issues Device CA&#xa;• Never online" style="rounded=1;fillColor=#1e1b4b;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="50" y="120" width="105" height="75" as="geometry"/></mxCell>
        <mxCell id="arr_ca" value="→" style="text;fontSize=18;fontColor=#7c3aed;fontStyle=1" vertex="1" parent="1"><mxGeometry x="160" y="145" width="20" height="25" as="geometry"/></mxCell>
        <mxCell id="devca" value="🔑 Device CA&#xa;(Guarded Server)&#xa;━━━━━━━━━━&#xa;• Issues device certs&#xa;• Protected signing key&#xa;• Revocation list" style="rounded=1;fillColor=#5b21b6;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="185" y="120" width="110" height="75" as="geometry"/></mxCell>
        <mxCell id="arr_ca2" value="→" style="text;fontSize=18;fontColor=#7c3aed;fontStyle=1" vertex="1" parent="1"><mxGeometry x="300" y="145" width="20" height="25" as="geometry"/></mxCell>
        <mxCell id="reg" value="📊 Device Registry&#xa;━━━━━━━━━━&#xa;• Enrolled devices&#xa;• Cert → Topic ACL&#xa;• Revocation status" style="rounded=1;fillColor=#8b5cf6;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="325" y="120" width="105" height="75" as="geometry"/></mxCell>
        <mxCell id="prov" value="📥 FACTORY PROVISIONING:&#xa;1. eFuse burn (secure keys)&#xa;2. DS Peripheral signing&#xa;3. CA issues certificate&#xa;4. Add to Broker ACL" style="rounded=1;fillColor=#ede9fe;strokeColor=#c4b5fd;fontSize=7;fontColor=#5b21b6;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="450" y="120" width="160" height="75" as="geometry"/></mxCell>
        <mxCell id="life" value="🔄 CERT LIFECYCLE:&#xa;• 90-day auto-rotate&#xa;• CSR via DS Peripheral&#xa;• CRL/OCSP checking" style="rounded=1;fillColor=#ede9fe;strokeColor=#c4b5fd;fontSize=7;fontColor=#5b21b6;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="625" y="120" width="130" height="75" as="geometry"/></mxCell>
        
        <!-- ZONE 1: IoT -->
        <mxCell id="z1" value="" style="rounded=1;fillColor=#fef2f2;strokeColor=#ef4444;strokeWidth=2;dashed=1" vertex="1" parent="1"><mxGeometry x="30" y="240" width="790" height="165" as="geometry"/></mxCell>
        <mxCell id="z1t" value="🔴 ZONE 1: IoT Device (ESP32-S3/C3)" style="text;fontSize=11;fontStyle=1;fontColor=#dc2626" vertex="1" parent="1"><mxGeometry x="45" y="248" width="280" height="16" as="geometry"/></mxCell>
        <mxCell id="hsm" value="🔐 ATECC608A / DS Peripheral&#xa;━━━━━━━━━━━━&#xa;• ECC Private Key (non-export)&#xa;• HW-accelerated TLS signing&#xa;• Device Certificate&#xa;• HMAC-derived key protection" style="rounded=1;fillColor=#1e293b;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="50" y="272" width="175" height="85" as="geometry"/></mxCell>
        <mxCell id="hard" value="🛡️ Device Hardening&#xa;━━━━━━━━━━━━&#xa;• Secure Boot V2 (RSA-3072)&#xa;• Flash Enc (AES-256-XTS)&#xa;• NVS Encryption&#xa;• JTAG Disabled (eFuse)&#xa;• Release Mode" style="rounded=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=7;fontColor=#166534;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="240" y="272" width="150" height="95" as="geometry"/></mxCell>
        <mxCell id="ble" value="📶 BLE 5.0 Security&#xa;━━━━━━━━━━━━&#xa;• Secure Connections&#xa;• OOB Pairing&#xa;• ECDH Key Exchange&#xa;• AES-128 Encryption" style="rounded=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=7;fontColor=#1e40af;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="405" y="272" width="130" height="85" as="geometry"/></mxCell>
        <mxCell id="z1_thr" value="THREATS:&#xa;• Device theft / tampering&#xa;• Key extraction attempts&#xa;• Firmware manipulation&#xa;• BLE eavesdropping" style="text;fontSize=7;fontColor=#991b1b;align=left" vertex="1" parent="1"><mxGeometry x="555" y="275" width="130" height="55" as="geometry"/></mxCell>
        <mxCell id="z1_ctrl" value="CONTROLS:&#xa;✓ HSM non-exportable keys&#xa;✓ Secure Boot + Flash Enc&#xa;✓ mTLS authentication&#xa;✓ Per-device unique CN" style="text;fontSize=7;fontColor=#065f46;align=left" vertex="1" parent="1"><mxGeometry x="690" y="275" width="120" height="55" as="geometry"/></mxCell>
        
        <!-- Trust Boundary 1 -->
        <mxCell id="tb1" value="━━━━━━━━━━━━━━━━━ IoT ↔ Edge Boundary: mTLS + AES-256-GCM (Port 8883) ━━━━━━━━━━━━━━━━━" style="text;fontSize=9;fontStyle=1;fontColor=#dc2626;align=center" vertex="1" parent="1"><mxGeometry x="30" y="415" width="790" height="16" as="geometry"/></mxCell>
        
        <!-- ZONE 2: Edge -->
        <mxCell id="z2" value="" style="rounded=1;fillColor=#fef9c3;strokeColor=#f59e0b;strokeWidth=2;dashed=1" vertex="1" parent="1"><mxGeometry x="30" y="440" width="790" height="165" as="geometry"/></mxCell>
        <mxCell id="z2t" value="🟡 ZONE 2: Edge Processor (Raspberry Pi 4) + MQTT Broker" style="text;fontSize=11;fontStyle=1;fontColor=#d97706" vertex="1" parent="1"><mxGeometry x="45" y="448" width="400" height="16" as="geometry"/></mxCell>
        <mxCell id="mqtt" value="📡 MQTT Broker (Mosquitto/EMQX)&#xa;━━━━━━━━━━━━━━&#xa;• Port 8883 (mTLS enforced)&#xa;• Server Cert + Key&#xa;• require_certificate=true&#xa;• CA Trust Store" style="rounded=1;fillColor=#78350f;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="50" y="472" width="175" height="85" as="geometry"/></mxCell>
        <mxCell id="certval" value="🔍 Cert Validation&#xa;━━━━━━━━━━━━━━&#xa;• TLS handshake&#xa;• Verify client cert&#xa;• CRL/OCSP check&#xa;• Match ACL rules" style="rounded=1;fillColor=#374151;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="240" y="472" width="120" height="85" as="geometry"/></mxCell>
        <mxCell id="tee" value="🔐 ARM TrustZone + OP-TEE&#xa;━━━━━━━━━━━━━━&#xa;• Secure key storage&#xa;• Protected processing&#xa;• TEE key protection&#xa;• Isolated execution" style="rounded=1;fillColor=#1e293b;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="375" y="472" width="145" height="85" as="geometry"/></mxCell>
        <mxCell id="acl" value="📋 ACL Rules:&#xa;device-ecg-001 → data/ecg/001&#xa;device-ecg-002 → data/ecg/002" style="rounded=1;fillColor=#fef3c7;strokeColor=#fcd34d;fontSize=7;fontColor=#92400e;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="535" y="472" width="155" height="45" as="geometry"/></mxCell>
        <mxCell id="z2_thr" value="THREATS: Unauthorized device • Topic hijacking • MITM" style="text;fontSize=7;fontColor=#92400e" vertex="1" parent="1"><mxGeometry x="535" y="525" width="260" height="12" as="geometry"/></mxCell>
        <mxCell id="z2_ctrl" value="CONTROLS: ✓ mTLS enforcement ✓ Client cert validation ✓ ACL ✓ TEE" style="text;fontSize=7;fontColor=#065f46" vertex="1" parent="1"><mxGeometry x="535" y="540" width="260" height="12" as="geometry"/></mxCell>
        
        <!-- Trust Boundary 2 -->
        <mxCell id="tb2" value="━━━━━━━━━━━━━━━━━ Edge ↔ Cloud Boundary: TLS 1.3 + PFS (ECDHE Keys) ━━━━━━━━━━━━━━━━━" style="text;fontSize=9;fontStyle=1;fontColor=#f59e0b;align=center" vertex="1" parent="1"><mxGeometry x="30" y="615" width="790" height="16" as="geometry"/></mxCell>
        
        <!-- ZONE 3: Cloud -->
        <mxCell id="z3" value="" style="rounded=1;fillColor=#ecfdf5;strokeColor=#10b981;strokeWidth=2;dashed=1" vertex="1" parent="1"><mxGeometry x="30" y="640" width="790" height="165" as="geometry"/></mxCell>
        <mxCell id="z3t" value="🟢 ZONE 3: Cloud Backend (FastAPI + SQLite)" style="text;fontSize=11;fontStyle=1;fontColor=#059669" vertex="1" parent="1"><mxGeometry x="45" y="648" width="350" height="16" as="geometry"/></mxCell>
        <mxCell id="api" value="🖥️ FastAPI Server" style="rounded=1;fillColor=#6ee7b7;strokeColor=#10b981;fontSize=9;fontStyle=1;fontColor=#064e3b" vertex="1" parent="1"><mxGeometry x="50" y="672" width="120" height="25" as="geometry"/></mxCell>
        <mxCell id="db" value="🗄️ SQLCipher DB&#xa;━━━━━━━━━━━━━━&#xa;• AES-256 at rest&#xa;• Argon2id passwords&#xa;• Hash-chain audit" style="rounded=1;fillColor=#1e293b;strokeColor=none;fontSize=7;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="50" y="705" width="130" height="75" as="geometry"/></mxCell>
        <mxCell id="auth" value="🎫 JWT + RBAC&#xa;━━━━━━━━━━━━━━&#xa;• HS256 algorithm&#xa;• 30 min expiry&#xa;• OAuth2 flow&#xa;• doctor/admin/device" style="rounded=1;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=7;fontColor=#1e40af;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="195" y="672" width="130" height="85" as="geometry"/></mxCell>
        <mxCell id="ledger" value="🔗 Cryptographic Audit Ledger&#xa;━━━━━━━━━━━━━━&#xa;• SHA-256 hash-chain&#xa;• Tamper-evident logging&#xa;• Every action recorded" style="rounded=1;fillColor=#d1fae5;strokeColor=#10b981;fontSize=7;fontColor=#065f46;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="340" y="672" width="165" height="75" as="geometry"/></mxCell>
        <mxCell id="z3_thr" value="THREATS: SQL injection • Auth bypass • Data breach" style="text;fontSize=7;fontColor=#059669" vertex="1" parent="1"><mxGeometry x="525" y="680" width="250" height="12" as="geometry"/></mxCell>
        <mxCell id="z3_ctrl" value="CONTROLS: ✓ SQLCipher encryption ✓ JWT tokens ✓ Argon2id hashing ✓ RBAC ✓ Audit trail" style="text;fontSize=7;fontColor=#065f46" vertex="1" parent="1"><mxGeometry x="525" y="695" width="260" height="12" as="geometry"/></mxCell>
        
        <!-- Trust Boundary 3 -->
        <mxCell id="tb3" value="━━━━━━━━━━━━━━━━━ Cloud ↔ Clinical Boundary: HTTPS TLS 1.3 + JWT Bearer ━━━━━━━━━━━━━━━━━" style="text;fontSize=9;fontStyle=1;fontColor=#10b981;align=center" vertex="1" parent="1"><mxGeometry x="30" y="815" width="790" height="16" as="geometry"/></mxCell>
        
