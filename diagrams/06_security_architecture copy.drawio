        <mxCell id="rootca" value="🔒 Root CA&#xa;(Air-Gapped Offline)&#xa;━━━━━━━━━━━&#xa;• Self-signed root cert&#xa;• Issues Device CA&#xa;• Never online" style="rounded=1;fillColor=#1f2937;strokeColor=#111827;fontSize=8;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="35" y="80" width="120" height="75" as="geometry"/></mxCell>
