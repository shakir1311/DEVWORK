        <mxCell id="z4t" value="🔵 ZONE 4: Web Portal (Clinician Dashboard)" style="text;fontSize=11;fontStyle=1;fontColor=#2563eb" vertex="1" parent="1"><mxGeometry x="45" y="848" width="350" height="16" as="geometry"/></mxCell>
        <mxCell id="dash" value="👨‍⚕️ Clinician Dashboard" style="rounded=1;fillColor=#93c5fd;strokeColor=#3b82f6;fontSize=10;fontStyle=1;fontColor=#1e3a8a" vertex="1" parent="1"><mxGeometry x="50" y="872" width="160" height="40" as="geometry"/></mxCell>
        <mxCell id="z4_ctrl" value="CONTROLS: ✓ HTTPS only ✓ Session timeout ✓ Action audit ✓ MFA (future)" style="text;fontSize=8;fontColor=#1e40af" vertex="1" parent="1"><mxGeometry x="230" y="880" width="350" height="14" as="geometry"/></mxCell>
        
        <!-- STRIDE Threats -->
        <mxCell id="stride" value="" style="rounded=1;fillColor=#fef2f2;strokeColor=#ef4444;strokeWidth=2" vertex="1" parent="1"><mxGeometry x="30" y="960" width="790" height="85" as="geometry"/></mxCell>
        <mxCell id="stride_t" value="⚔️ STRIDE THREAT MITIGATIONS" style="text;fontSize=10;fontStyle=1;fontColor=#dc2626" vertex="1" parent="1"><mxGeometry x="45" y="968" width="220" height="14" as="geometry"/></mxCell>
        <mxCell id="s1" value="S Spoofing → HSM Keys + Device Certs + mTLS" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="45" y="985" width="220" height="10" as="geometry"/></mxCell>
        <mxCell id="s2" value="T Tampering → Hash-Chain + Secure Boot + HSM" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="45" y="997" width="230" height="10" as="geometry"/></mxCell>
        <mxCell id="s3" value="R Repudiation → Immutable Audit + Timestamps" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="45" y="1009" width="220" height="10" as="geometry"/></mxCell>
        <mxCell id="s4" value="I Info Disclosure → AES-256 + TLS 1.3 + SQLCipher" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="280" y="985" width="240" height="10" as="geometry"/></mxCell>
        <mxCell id="s5" value="D Denial of Svc → Local Fail-Safe + Rate Limit" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="280" y="997" width="220" height="10" as="geometry"/></mxCell>
        <mxCell id="s6" value="E Elevation → RBAC + Least Privilege + TEE" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="280" y="1009" width="200" height="10" as="geometry"/></mxCell>
        <mxCell id="s7" value="Session Hijack → JWT 30m Expiry" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="540" y="985" width="160" height="10" as="geometry"/></mxCell>
        <mxCell id="s8" value="Key Extraction → HSM/TEE Hardware Protection" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="540" y="997" width="220" height="10" as="geometry"/></mxCell>
        <mxCell id="s9" value="Past Sessions → PFS Ephemeral Keys" style="text;fontSize=7;fontColor=#374151" vertex="1" parent="1"><mxGeometry x="540" y="1009" width="180" height="10" as="geometry"/></mxCell>
        
