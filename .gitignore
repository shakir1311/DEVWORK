# =============================================================================
# BIEIF-RPM - GitHub .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# EXCLUDED MATERIALS (papers, thesis, literature, etc.)
# -----------------------------------------------------------------------------
exclude/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
ENV/
.eggs/
*.egg-info/
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# ML MODEL ARTIFACTS (large files - use Git LFS or download separately)
# -----------------------------------------------------------------------------
*.pt
*.pth
*.ckpt
*.h5
*.pkl
*.onnx
wandb/
mlruns/
lightning_logs/

# -----------------------------------------------------------------------------
# DATABASE FILES
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# NODE / WEB
# -----------------------------------------------------------------------------
node_modules/
.next/
dist/

# -----------------------------------------------------------------------------
# IDE & SYSTEM
# -----------------------------------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp
*~

# -----------------------------------------------------------------------------
# CREDENTIALS & SECRETS
# -----------------------------------------------------------------------------
.env
.env.local
*.pem
*.key

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
