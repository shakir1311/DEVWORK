        <mxCell id="deviceca" value="� Device CA&#xa;(Guarded Server)&#xa;━━━━━━━━━━━&#xa;• Issues device certs&#xa;• Protected signing key&#xa;• Revocation list" style="rounded=1;fillColor=#374151;strokeColor=#1f2937;fontSize=8;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="35" y="170" width="120" height="75" as="geometry"/></mxCell>
