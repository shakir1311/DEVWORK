        <mxCell id="z1t" value="🔴 ZONE 1: IoT Device (ESP32)" style="text;html=1;align=center;fontSize=10;fontStyle=1;fontColor=#dc2626" vertex="1" parent="1"><mxGeometry x="240" y="58" width="230" height="16" as="geometry"/></mxCell>
        
        <mxCell id="esp" value="⚡ ESP32 MCU + Secure Boot" style="rounded=1;fillColor=#fecaca;strokeColor=#dc2626;fontSize=9;fontStyle=1" vertex="1" parent="1"><mxGeometry x="255" y="80" width="150" height="28" as="geometry"/></mxCell>
        <mxCell id="hsm" value="🔐 ATECC608A (HSM)&#xa;━━━━━━━━━━━&#xa;• ECC Private Key&#xa;  (non-exportable)&#xa;• AES-256 Session Key&#xa;• Device Certificate&#xa;• Unique ID (CN)" style="rounded=1;fillColor=#374151;strokeColor=#1f2937;fontSize=8;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="255" y="115" width="130" height="90" as="geometry"/></mxCell>
        
        <mxCell id="z1_sec" value="SECURITY CONTROLS:&#xa;✓ HSM non-exportable keys&#xa;✓ Device cert (signed by CA)&#xa;✓ mTLS authentication&#xa;✓ Secure Boot + Flash Enc&#xa;✓ Per-device unique CN" style="text;html=1;align=left;fontSize=7;fontColor=#064e3b" vertex="1" parent="1"><mxGeometry x="255" y="215" width="130" height="70" as="geometry"/></mxCell>
        <mxCell id="z1_threat" value="THREATS:&#xa;• Device impersonation&#xa;• Key extraction&#xa;• Cert forgery" style="text;html=1;align=left;fontSize=7;fontColor=#7f1d1d" vertex="1" parent="1"><mxGeometry x="385" y="215" width="80" height="55" as="geometry"/></mxCell>
        
        <mxCell id="onboard" value="📥 ONBOARDING FLOW:&#xa;1. HSM generates ECC keypair&#xa;2. Create CSR&#xa;3. CA signs → Device Cert&#xa;4. Load cert to ESP32&#xa;5. Add to Broker ACL" style="rounded=0;fillColor=#fef3c7;strokeColor=#f59e0b;fontSize=7;fontColor=#92400e;align=left;spacingLeft=3" vertex="1" parent="1"><mxGeometry x="255" y="285" width="140" height="65" as="geometry"/></mxCell>
        
