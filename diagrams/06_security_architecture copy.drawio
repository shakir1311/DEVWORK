        <mxCell id="mqtt" value="� MQTT Broker&#xa;(Mosquitto/EMQX)&#xa;━━━━━━━━━━━&#xa;• Port 8883 (mTLS)&#xa;• Server Cert + Key&#xa;• require_certificate=true&#xa;• CA Trust Store" style="rounded=1;fillColor=#92400e;strokeColor=#78350f;fontSize=8;fontColor=#fff;align=left;spacingLeft=4" vertex="1" parent="1"><mxGeometry x="545" y="115" width="125" height="90" as="geometry"/></mxCell>
        
